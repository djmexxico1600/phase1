# ============================================================
# BeatForge — .gitignore
# ============================================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Build outputs ----
.next/
dist/
.turbo/
.wrangler/
storybook-static/
out/

# ---- Environment files ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.dev.vars

# ---- Coverage & Test artifacts ----
coverage/
.nyc_output/
playwright-report/
test-results/
*.snap

# ---- TypeScript ----
*.tsbuildinfo

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- OS artifacts ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- Editor artifacts ----
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# ---- Vercel (conventional, not primary deploy target) ----
.vercel

# ---- Cloudflare ----
.wrangler/
worker-configuration.d.ts

# ---- Sentry ----
.sentryclirc

# ---- Misc ----
*.min.js
.cache/
