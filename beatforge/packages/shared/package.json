{
  "name": "@beatforge/shared",
  "version": "1.0.0",
  "private": true,
  "description": "BeatForge shared types, schemas, and utilities",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
