# ============================================================
# BeatForge — Environment Variables Template
# Copy to .env.local (never commit actual secrets)
# ============================================================

# ---- Neon Postgres ----
NEON_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
NEON_DATABASE_URL_UNPOOLED=postgresql://user:pass@host/dbname?sslmode=require

# ---- Better Auth ----
BETTER_AUTH_SECRET=replace-with-32-bytes-random-secret
BETTER_AUTH_URL=http://localhost:3000

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- Cloudflare R2 ----
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=beatforge-media
R2_PUBLIC_URL=https://media.beatforge.io

# ---- Cloudflare KV / Queues (via wrangler bindings, not env) ----
# These are bound in wrangler.toml; listed here for docs only
# KV_NAMESPACE_ID=
# QUEUE_ID=

# ---- Resend (email) ----
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@beatforge.io

# ---- Sentry ----
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=beatforge
SENTRY_PROJECT=beatforge-web
NEXT_PUBLIC_SENTRY_DSN=$SENTRY_DSN

# ---- PostHog Analytics ----
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Cloudflare Turnstile ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# ---- App Config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BeatForge
NODE_ENV=development
